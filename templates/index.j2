
{# ── Derive latest issue metadata ── #}
{% set lmeta = latest.meta if latest else {} %}
{% set lc    = latest.components if latest else {} %}
{% set lspreads = lc.get('spreads', []) %}
{% set lbrief   = lc.get('executive_brief', {}) %}

<nav>
  <a href="index.html" class="nb">Antifragile <span>Africa</span></a>
  <ul class="nl">
    <li><a href="index.html" class="active">Reports</a></li>
    <li><a href="about.html">About</a></li>
    <li class="nd">
      <span class="nd-t">Legal</span>
      <div class="nd-m">
        <a href="terms.html">Terms of Service</a>
        <a href="privacy.html">Privacy Policy</a>
        <a href="disclaimer.html">Disclaimer</a>
      </div>
    </li>
    {% if lmeta.filename %}
    <li><a href="{{ lmeta.filename }}" class="nav-cta">Latest Issue →</a></li>
    {% endif %}
  </ul>
</nav>

{# ── TICKER — built from latest issue spreads ── #}
<div class="ticker">
  <div class="tl">Live Signals</div>
  <div class="tt">
    {% for s in lspreads %}
    <span class="ti"><span class="ti-l">{{ s.country | upper }}</span><span class="ti-v">{{ s.val }}</span><span class="{{ s.trend_cls }}">{{ s.trend }}</span></span>
    <span class="t-sep">·</span>
    {% endfor %}
    {% if lmeta.audit %}
    <span class="ti"><span class="ti-l">VOL. {{ lmeta.vol }} AUDIT</span><span class="ti-v">{{ lmeta.audit }} / 5.0</span><span class="t-up">{{ lmeta.agents }} AGENTS · {{ lmeta.layers }} LAYERS</span></span>
    <span class="t-sep">·</span>
    {% endif %}
    {# duplicate for seamless loop #}
    {% for s in lspreads %}
    <span class="ti"><span class="ti-l">{{ s.country | upper }}</span><span class="ti-v">{{ s.val }}</span><span class="{{ s.trend_cls }}">{{ s.trend }}</span></span>
    <span class="t-sep">·</span>
    {% endfor %}
    {% if lmeta.audit %}
    <span class="ti"><span class="ti-l">VOL. {{ lmeta.vol }} AUDIT</span><span class="ti-v">{{ lmeta.audit }} / 5.0</span><span class="t-up">{{ lmeta.agents }} AGENTS · {{ lmeta.layers }} LAYERS</span></span>
    <span class="t-sep">·</span>
    {% endif %}
  </div>
</div>

{# ── HERO ── #}
<section class="hero">
  <div class="hl">
    <div class="hk fu fu1">Weekly Intelligence · Est. March 2026</div>
    <h1 class="fu fu2">Where Disorder<br>Becomes <em>Advantage</em></h1>
    <p class="htag fu fu3">Institutional-grade intelligence on African crypto markets. Capital flows, regulatory arbitrage, OTC signals, and hidden trades — for allocators who understand that Africa's monetary dysfunction is crypto's greatest growth engine.</p>
    <div class="hcta fu fu4">
      {% if lmeta.filename %}
      <a href="{{ lmeta.filename }}" class="btn-p">Read Latest Issue →</a>
      {% endif %}
      <a href="about.html" class="btn-s">Our Thesis</a>
    </div>
  </div>
  <div class="hr">
    <div class="hs fu fu2">
      <div class="hsr">
        <div class="sn">54<em>+</em></div>
        <div class="sd">African states tracked weekly across all regulatory classifications</div>
      </div>
      <div class="hsr">
        <div class="sn">{{ lmeta.agents or '28' }}<em>AI</em></div>
        <div class="sd">Specialist agents and {{ lmeta.layers or '7' }} analytical layers per issue</div>
      </div>
      <div class="hsr">
        <div class="sn">$1<em>T+</em></div>
        <div class="sd">Estimated annual informal crypto-adjacent capital flows on the continent</div>
      </div>
    </div>
    <div class="hth fu fu3">
      <span class="thl">Core Thesis</span>
      <div class="tht">"Africa already has the world's most advanced crypto use case in production, at scale. It just doesn't look like what the Western industry built."</div>
    </div>
  </div>
</section>

<div class="container">
{# ── FEATURED LATEST ISSUE ── #}
{% if latest %}
<section class="fi">
  <div class="s-ey">Latest Report</div>
  <div class="s-t">This Week's <em>Intelligence</em></div>
  <p class="s-sub">Vol. {{ lmeta.vol }} — {{ lmeta.date }}{% if lmeta.agents %} — {{ lmeta.agents }} agents, {{ lmeta.layers }} layers{% endif %}</p>
  <div class="fc">
    <div class="fb-c">
      <div class="fmet">
        {% for b in lmeta.get('badges', []) %}
        <span class="badge {{ b.cls }}">{{ b.text }}</span>
        {% endfor %}
        {% if not lmeta.get('badges') %}
        <span class="badge badge-vol">Latest</span>
        {% endif %}
        <span class="fdate">{{ lmeta.date }}</span>
        <span class="fvol">Vol. {{ lmeta.vol }}</span>
      </div>
      <a href="{{ lmeta.filename or '#' }}" class="ftit">{{ lmeta.title | title_html }}</a>
      {% if lmeta.standfirst %}
      <p class="fdesc">{{ lmeta.standfirst }}</p>
      {% endif %}
      {# Key bullet points from exec brief paragraphs or standfirst #}
      {% set opps = lc.get('opportunities', []) %}
      {% if opps %}
      <ul class="fhl">
        {% for opp in opps[:5] %}
        <li>{{ opp.title | safe }}</li>
        {% endfor %}
      </ul>
      {% endif %}
      <a href="{{ lmeta.filename or '#' }}" class="btn-p">Read Full Report →</a>
    </div>
    {# Spreads sidebar #}
    <div class="fsd">
      <span class="sbl">This Week's Spreads</span>
      {% for s in lspreads %}
      <div class="sm">
        <div class="sc-l">{{ s.country }}</div>
        <div class="sv {{ s.val_cls }}">{{ s.val }}</div>
        <div class="{{ s.trend_cls }}">{{ s.trend }}</div>
        {% if s.note %}<div class="snote">{{ s.note }}</div>{% endif %}
      </div>
      {% endfor %}
      {% if lmeta.audit %}
      <div class="sm">
        <div class="sc-l">Audit Score</div>
        <div class="sv green">{{ lmeta.audit }}</div>
        <div class="snote">Out of 5.0 — PASS ✓</div>
      </div>
      {% endif %}
    </div>
  </div>
</section>
{% endif %}

{# ── ARCHIVE GRID ── #}
<section class="ar">
  <div class="s-ey">Archive</div>
  <div class="s-t">All <em>Reports</em></div>
  <p class="s-sub">Every issue, permanently available. Intelligence compounds.</p>
  <div class="ag">
    {% for issue in issues %}
    {% set imeta = issue.meta %}
    {% set ic    = issue.components %}
    {# Determine card style: pilot issues get gold accent #}
    {% set is_pilot = 'pilot' in (imeta.vol or '') | lower or '00' in (imeta.vol or '') %}
    <a href="{{ imeta.filename or '#' }}" class="ac {{ 'pilot' if is_pilot else '' }}">
      <div class="acd">
        {{ imeta.date }}
        <span class="acv {{ 'pilot' if is_pilot else '' }}">
          {{ 'Pilot / Vol. 00' if is_pilot else 'Vol. ' ~ imeta.vol }}
        </span>
      </div>
      <div class="act">{{ imeta.title_plain or imeta.title }}</div>
      {% if imeta.standfirst %}
      <div class="ace">{{ imeta.standfirst[:160] }}{% if imeta.standfirst | length > 160 %}…{% endif %}</div>
      {% endif %}
      {# Tag cloud from spreads countries #}
      {% set sp = ic.get('spreads', []) %}
      <div class="ats">
        {% for s in sp[:5] %}
        <span class="at">{{ s.country.split('·')[0].strip() }}</span>
        {% endfor %}
        {% if imeta.new_signal %}
        <span class="at">{{ imeta.new_signal }}</span>
        {% endif %}
      </div>
    </a>
    {% else %}
    {# No issues found — placeholder #}
    <div class="ac" style="opacity:.4;pointer-events:none;">
      <div class="acd">Coming Soon<span class="acv">Vol. 01</span></div>
      <div class="act">First Issue Publishing Soon</div>
      <div class="accoming"><span class="aclbl">Coming Soon</span></div>
    </div>
    {% endfor %}
  </div>
</section>
{# ── THESIS PILLARS ── #}
<section class="ps">
  <div class="s-ey">Core Framework</div>
  <div class="s-t">Crypto in Africa is <em>Not Speculation</em></div>
  <p class="s-sub">Four structural roles — enforced across every report, every week.</p>
  <div class="pg">
    <div class="pi">
      <span class="pi-n">1</span><span class="pi-i">🛡️</span>
      <div class="pi-t">FX Hedge</div>
      <div class="pi-d">In markets where currency depreciation exceeds 18% annually, holding stablecoins is not speculation. It is rational treasury management.</div>
    </div>
    <div class="pi">
      <span class="pi-n">2</span><span class="pi-i">🔥</span>
      <div class="pi-t">Inflation Hedge</div>
      <div class="pi-d">Every percentage point of inflation above 15% correlates with measurable stablecoin adoption growth. Disorder is the engine, not the barrier.</div>
    </div>
    <div class="pi">
      <span class="pi-n">3</span><span class="pi-i">✈️</span>
      <div class="pi-t">Capital Flight Rail</div>
      <div class="pi-d">High-net-worth capital, SME trade flows, and diaspora remittances are all migrating to crypto rails — not for ideology, but for efficiency.</div>
    </div>
    <div class="pi">
      <span class="pi-n">4</span><span class="pi-i">🏗️</span>
      <div class="pi-t">Shadow Banking</div>
      <div class="pi-d">The real African crypto market is informal, P2P, and invisible to Western analytics. This is not a bug. It is the entire story.</div>
    </div>
  </div>
</section>

{# ── NEWSLETTER ── #}
<section class="ns">
  <div class="ni">
    <div>
      <div class="s-ey">Stay Informed</div>
      <div class="nt">Weekly intelligence<br><em>delivered direct</em></div>
      <p class="nsub">Every week — institutional-grade analysis of African crypto capital flows, regulatory shifts, OTC signals, and asymmetric opportunities. No noise. No speculation theater. Intelligence that compounds.</p>
    </div>
    <div class="nf">
      <span class="fn2">Subscribe to the weekly report</span>
      <div class="nr">
        <input type="email" placeholder="your@email.com">
        <button type="button">Subscribe</button>
      </div>
      <p class="nd2">Institutional and professional allocators only. No financial advice. Simulated data where noted. Unsubscribe at any time.</p>
    </div>
  </div>
</section>

</div>{# /container #}

{# ── FOOTER ── #}
<footer>
  <div class="fg">
    <div class="fb2">
      <span class="brand">Antifragile <em>Africa</em></span>
      <p>Institutional intelligence on African crypto markets. Built on Thiel's secrets and Taleb's antifragility — for allocators who understand that disorder is the opportunity.</p>
    </div>
    <div>
      <span class="fct">Reports</span>
      <ul class="fl">
        {% for issue in issues[:6] %}
        <li><a href="{{ issue.meta.filename or '#' }}">Vol. {{ issue.meta.vol }} — {{ issue.meta.date }}</a></li>
        {% endfor %}
      </ul>
    </div>
    <div>
      <span class="fct">Publication</span>
      <ul class="fl">
        <li><a href="about.html">About &amp; Thesis</a></li>
        <li><a href="about.html#methodology">Methodology</a></li>
        <li><a href="about.html#agents">Agent System</a></li>
      </ul>
    </div>
    <div>
      <span class="fct">Coverage</span>
      <ul class="fl">
        <li><a href="#">Nigeria · Lagos OTC</a></li>
        <li><a href="#">Kenya · East Africa</a></li>
        <li><a href="#">South Africa · ZAR</a></li>
        <li><a href="#">WAEMU · CFA Bloc</a></li>
        <li><a href="#">54 African States</a></li>
      </ul>
    </div>
    <div>
      <span class="fct">Legal</span>
      <ul class="fl">
        <li><a href="terms.html">Terms of Service</a></li>
        <li><a href="privacy.html">Privacy Policy</a></li>
        <li><a href="disclaimer.html">Disclaimer</a></li>
      </ul>
    </div>
  </div>
  <div class="fbot">
    <span class="fc2">© 2026 Antifragile Africa Crypto · All Rights Reserved</span>
    <div style="display:flex;gap:1.5rem;align-items:center;flex-wrap:wrap;justify-content:flex-end;">
      <div style="display:flex;gap:1.5rem;">
        <a href="terms.html" style="font-family:'IBM Plex Mono',monospace;font-size:.58rem;letter-spacing:.12em;text-transform:uppercase;color:var(--mid);text-decoration:none;" onmouseover="this.style.color='var(--steel)'" onmouseout="this.style.color='var(--mid)'">Terms</a>
        <a href="privacy.html" style="font-family:'IBM Plex Mono',monospace;font-size:.58rem;letter-spacing:.12em;text-transform:uppercase;color:var(--mid);text-decoration:none;" onmouseover="this.style.color='var(--steel)'" onmouseout="this.style.color='var(--mid)'">Privacy</a>
        <a href="disclaimer.html" style="font-family:'IBM Plex Mono',monospace;font-size:.58rem;letter-spacing:.12em;text-transform:uppercase;color:var(--mid);text-decoration:none;" onmouseover="this.style.color='var(--steel)'" onmouseout="this.style.color='var(--mid)'">Disclaimer</a>
      </div>
      <span class="fd2">For institutional and professional use only. Not financial advice. Simulated data where noted. All figures are estimates or model outputs. Past signals do not guarantee future accuracy.</span>
    </div>
  </div>
</footer>

</body>
</html
